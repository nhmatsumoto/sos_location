# SOS_LOCATION — variáveis de ambiente de desenvolvimento.
# Copie para .env e ajuste. NUNCA commite senhas reais.

# PostgreSQL / PostGIS (fonte autoritativa)
POSTGRES_DB=sos_location
POSTGRES_USER=sos
POSTGRES_PASSWORD=sos_dev_password
POSTGRES_PORT=5432

# MinIO (armazenamento de dados brutos, compatível com S3)
MINIO_ROOT_USER=sos-minio
MINIO_ROOT_PASSWORD=sos_minio_dev_password
MINIO_BUCKET=sos-location
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Portas expostas
API_PORT=5080
WEB_PORT=8080

# Observabilidade (opcional): exportador OTLP
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
