FRONTEND_PORT=8088
BACKEND_PORT=8001
DOZZLE_PORT=9999
DOZZLE_LEVEL=info
DOZZLE_TAILSIZE=300

DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
SECRET_KEY=troque-isto

DB_ENGINE=django.db.backends.postgresql
DB_NAME=sos_location
DB_USER=sos_location_user
DB_PASSWORD=sos_location_password
DB_HOST=postgres
DB_PORT=5432

# Frontend (Vite)
# Em desenvolvimento use proxy (frontend -> /api -> backend), sem base URL absoluta.
VITE_API_BASE_URL=http://localhost:8001
# Segurança de integração: quando false/vazio, ignora base loopback (localhost/127.0.0.1)
# se o frontend estiver publicado em domínio remoto.
VITE_API_ALLOW_LOOPBACK=false
VITE_DEV_API_TARGET=http://localhost:8001

GMAPS_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=

KEYCLOAK_ENABLED=true
KEYCLOAK_SERVER_URL=https://localhost:8080
KEYCLOAK_REALM=sos-location
KEYCLOAK_CLIENT_ID=sos-location-frontend
KEYCLOAK_VERIFY_AUDIENCE=true
KEYCLOAK_ROLE_ADMIN=sos_admin
KEYCLOAK_ROLE_OPERATOR=sos_operator
KEYCLOAK_ROLE_VIEWER=sos_viewer
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
SEED_ON_STARTUP=true
RUN_INTEGRATIONS_ON_STARTUP=true

# Data Hub / Integrations
TRANSPARENCIA_API_KEY=
TRANSPARENCIA_BASE_URL=https://api.portaldatransparencia.gov.br/api-de-dados
TRANSPARENCIA_TRANSFERS_PATH=/transferencias
TRANSPARENCIA_SEARCH_PATH=/busca-livre
CACHE_DIR=.cache
ENABLE_GOES=false
ENABLE_STAC=true
# Lista de feeds CAP (separados por vírgula)
CAP_ALERT_FEEDS=https://apiprevmet3.inmet.gov.br/avisos/rss

# Security baseline
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
CSRF_TRUSTED_ORIGINS=
# CORS fallback para cenários sem proxy (ex.: frontend em :8088 e backend em :8001)
API_CORS_ORIGINS=http://localhost:8088,http://127.0.0.1:8088,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:8088,http://127.0.0.1:8088,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_LOCALHOST_ANY_PORT=True
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept,Origin,X-Requested-With,X-CSRFToken,X-Csrftoken
CORS_PREFLIGHT_MAX_AGE=600
# SECURITY_CSP=default-src 'self'; ...

GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
MIGRATE_MAX_ATTEMPTS=24

DB_CONN_MAX_AGE=120
DB_CONN_HEALTH_CHECKS=True
DB_CONNECT_TIMEOUT=10
DB_STATEMENT_TIMEOUT_MS=120000
DB_LOCK_TIMEOUT_MS=15000
DB_IDLE_IN_TX_TIMEOUT_MS=60000
DB_APPLICATION_NAME=mg-location-backend

# Disaster crawler
DISASTERS_GDACS_ENABLED=true
DISASTERS_USGS_ENABLED=true
DISASTERS_INMET_ENABLED=false
DISASTERS_FIRMS_ENABLED=false
DISASTERS_FIRMS_MAP_KEY=
DISASTERS_POLLING_SECONDS=300

RISK_AGENT_URL=http://risk-agent:8091
RISK_AGENT_INTERNAL_TOKEN=mg-location-internal-token

# GIS Data Providers (City-Scale 3D Simulation)
OPENTOPOGRAPHY_URL=https://portal.opentopography.org/API/globaldem
OPENTOPOGRAPHY_API_KEY=
OVERPASS_URL=https://overpass-api.de/api/interpreter
OPENMETEO_URL=https://api.open-meteo.com/v1/forecast
NASA_EARTHDATA_TOKEN=
GIS_CACHE_EXPIRATION_MINUTES=15
GIS_INDEXING_INTERVAL_MINUTES=30

# Japan GIS Sources (planned)
# GSI_TILES_URL=https://cyberjapandata.gsi.go.jp/xyz
# JAPAN_GXML_API_URL=

# Brazil Cadastral Sources (planned)
