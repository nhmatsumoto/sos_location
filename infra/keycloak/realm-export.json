{
  "realm": "sos-location",
  "enabled": true,
  "registrationAllowed": true,
  "loginTheme": "sos-theme",
  "rememberMe": true,
  "resetPasswordAllowed": true,
  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": false,
      "config": {
        "clientId": "placeholder",
        "clientSecret": "placeholder"
      }
    },
    {
      "alias": "facebook",
      "providerId": "facebook",
      "enabled": false,
      "config": {
        "clientId": "placeholder",
        "clientSecret": "placeholder"
      }
    }
  ],
  "clients": [
    {
      "clientId": "sos-location-frontend",
      "publicClient": true,
      "protocol": "openid-connect",
      "redirectUris": [
        "https://localhost:8088/*",
        "https://127.0.0.1:8088/*",
        "https://0.0.0.0:8088/*",
        "http://localhost:8088/*",
        "http://127.0.0.1:8088/*",
        "http://localhost:8000/*",
        "http://127.0.0.1:8000/*",
        "http://0.0.0.0:8088/*"
      ],
      "webOrigins": [
        "https://localhost:8088",
        "https://127.0.0.1:8088",
        "https://0.0.0.0:8088",
        "http://localhost:8088",
        "http://127.0.0.1:8088",
        "http://localhost:8000",
        "http://127.0.0.1:8000",
        "http://0.0.0.0:8088",
        "+"
      ],
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "volunteer"
      },
      {
        "name": "coordinator"
      },
      {
        "name": "admin"
      },
      {
        "name": "public"
      }
    ]
  },
  "users": [
