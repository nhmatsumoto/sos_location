{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=sos_location;Username=postgres;Password=password"
  },
  "AllowedOrigins": [
    "http://localhost:8088",
    "https://localhost:8088"
  ],
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/sos-location",
    "Audience": "sos-location-frontend",
    "Audiences": [ "sos-location-frontend", "account" ],
    "RequireHttpsMetadata": true,
    "VerifyAudience": true
  },
  "Database": {
    "ApplyMigrationsOnStartup": true,
    "SeedOnStartup": true
  },
  "ExternalIntegrations": {
    "InmetUrl": "https://apiprevmet3.inmet.gov.br/avisos/ativos",
    "OpenTopographyUrl": "https://portal.opentopography.org/API/globaldem",
    "OverpassUrl": "https://overpass-api.de/api/interpreter",
    "MapboxToken": "YOUR_MAPBOX_TOKEN_HERE",
    "MapboxUrl": "https://api.mapbox.com/v4/mapbox.terrain-rgb/{z}/{x}/{y}.pngraw",
    "AwsTerrainUrl": "https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png"
  }
}
