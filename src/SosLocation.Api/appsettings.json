{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=sos_location;Username=sos;Password=sos_dev_password"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "ImportLimits": {
    "MaximumImportAreaKm2": 250,
    "MaximumUploadBytes": 104857600,
    "MaximumDownloadBytes": 209715200,
    "MaximumFeatureCount": 500000,
    "MaximumVerticesPerFeature": 50000,
    "ExternalProcessTimeoutSeconds": 300,
    "AllowedImportHosts": [
      "overpass-api.de",
      "nominatim.openstreetmap.org",
      "download.geofabrik.de"
    ]
  },
  "Nominatim": {
    "BaseUrl": "https://nominatim.openstreetmap.org"
  },
  "Overpass": {
    "BaseUrl": "https://overpass-api.de",
    "QueryTimeoutSeconds": 120
  },
  "Fixture": {
    "Path": "tools/fixtures/demo-district.geojson"
  },
  "ObjectStorage": {
    "Endpoint": "localhost:9000",
    "AccessKey": "sos-minio",
    "SecretKey": "sos_minio_dev_password",
    "Bucket": "sos-location",
    "UseSsl": false
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173", "http://localhost:8080"]
  },
  "AllowedHosts": "*"
}
